# ─── REQUIRED — change before deploying ───────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# ─── COUPLE CREDENTIALS ───────────────────────────────────────────────────────
USER1_NAME=Sarojana
USER1_PASS=love24

USER2_NAME=Rushi
USER2_PASS=love24

# ─── PRODUCTION CONFIG ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── URLS ─────────────────────────────────────────────────────────────────────
# For Railway deployment: leave CLIENT_URL blank (Railway sets it automatically)
# For other platforms: set to your deployment domain
CLIENT_URL=

# VITE_API_URL is only needed if frontend & backend are on different domains.
# Leave blank when deploying full-stack to same domain.
VITE_API_URL=
